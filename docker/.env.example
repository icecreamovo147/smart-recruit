# =============================================================================
# 智能招聘系统 — Docker Compose 环境变量模板
# =============================================================================
# 使用方法:
#   cp docker/.env.example docker/.env
#   编辑 docker/.env，填入你的真实密钥
#
# 注意: docker/.env 已加入 .gitignore，不会提交到仓库。
# =============================================================================

# ---- 时区配置 ----
# 影响容器内日志时间、Go time.Local 以及数据库系统时区。
TZ=Asia/Shanghai

# ---- 内部通信令牌（必填） ----
# gRPC 内部认证令牌，Web 与 Logic 服务通信时使用。
# 本地开发可用任意值，生产环境请生成随机字符串。
GRPC_INTERNAL_TOKEN=dev-shared-token

# ---- JWT 签名密钥 ----
# Web 与 Logic 服务必须使用相同的 JWT 密钥。
# 生产环境请使用 >= 32 字符的强随机字符串。
JWT_SECRET=dev-jwt-secret-at-least-32-chars-long!!

# ---- AI 配置（必填） ----
# 阿里云百炼 API Key: https://bailian.console.aliyun.com/
AI_API_KEY=sk-your-api-key-here
# 模型名称: qwen-plus / qwen-max / qwen-turbo 等
AI_MODEL=qwen-plus
# AI Agent 运行时: adk / legacy
AI_AGENT_RUNTIME=adk

# ---- 对象存储（必填） ----
# 用于存储候选人上传的简历文件。
# 默认使用腾讯云 COS，也可切换为阿里云 OSS。

# 存储提供商: tencent_cos / aliyun_oss
OSS_PROVIDER=tencent_cos

# ---- 腾讯云 COS 配置 ----
# 如果使用阿里云 OSS，可留空以下 COS 字段。
OSS_ENDPOINT=cos.ap-shanghai.myqcloud.com
OSS_ACCESS_KEY_ID=your-secret-id
OSS_ACCESS_KEY_SECRET=your-secret-key
OSS_BUCKET_NAME=bucket-name-appid
OSS_PUBLIC_BASE_URL=https://bucket-name-appid.cos.ap-shanghai.myqcloud.com

# ---- 阿里云 OSS 配置（可选，切换到 aliyun_oss 时使用） ----
# OSS_PROVIDER=aliyun_oss
# OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_BUCKET_NAME=your-bucket
# OSS_PUBLIC_BASE_URL=

# ---- CORS 跨域配置 ----
# 前端访问后端的允许来源，多个用逗号分隔。
# 本地 Docker 部署使用默认值即可。
CORS_ALLOWED_ORIGIN=http://localhost:5173,http://localhost:5174

# ---- Cookie 安全策略 ----
# 生产 HTTPS 环境设置为 true，本地 HTTP 环境设置为 false。
AUTH_COOKIE_SECURE=false

# ---- 登录 Cookie 名称 ----
# HR 端与候选人端必须使用不同 Cookie，避免同一 localhost 下互相覆盖登录态。
CANDIDATE_AUTH_COOKIE_NAME=recruitment_candidate_token
HR_AUTH_COOKIE_NAME=recruitment_hr_token

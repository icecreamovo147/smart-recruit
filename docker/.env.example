# ============================================================
# AI 配置
# ============================================================
AI_API_KEY=sk-your-api-key-here
AI_MODEL=qwen-plus

# ============================================================
# OSS 对象存储配置（腾讯云 COS）
# ============================================================
OSS_ENDPOINT=cos.ap-shanghai.myqcloud.com
OSS_ACCESS_KEY_ID=your-secret-id
OSS_ACCESS_KEY_SECRET=your-secret-key
OSS_BUCKET_NAME=your-bucket-name-appid
OSS_PUBLIC_BASE_URL=https://your-bucket-name-appid.cos.ap-shanghai.myqcloud.com

# ============================================================
# Docker BuildKit 加速
# ============================================================
COMPOSE_DOCKER_CLI_BUILD=1
DOCKER_BUILDKIT=1
